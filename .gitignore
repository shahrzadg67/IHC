outputs/masks/
# Regenerable HTML report + per-run provenance (run_all.py recreates these).
outputs/report/
outputs/run_provenance.txt
# QC sheets (outputs/qc/, outputs/qc_seg/, outputs/qc_quant/) and notebooks/ ARE tracked — they showcase results.

